// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth.js / Auth.js v5 Adapter Tables ─────────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  /// Bcrypt hash for Credentials (email/password) login. Null for OAuth-only users.
  password_hash String?
  /// Lumina Sparks credit balance. New users start with 5 free credits.
  credits         Int       @default(5)
  /// Lifetime USD spent by this user (Gross Revenue).
  total_spent_usd Decimal   @default(0.0000) @db.Decimal(10, 4)
  createdAt       DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  batches       Batch[]
  jobs          Job[]
  adminLogs     AdminAuditLog[]
  bugReports    BugReport[]
  storeAnalyses StoreAnalysis[]

  @@index([total_spent_usd])
  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Application Models ───────────────────────────────────────────────────────

model Batch {
  id        String   @id @default(uuid())
  userId    String
  status    String   @default("pending")
  /// Full JSON metadata: input data, product info, strategy array, etc.
  metadata    Json?
  cost_usd    Decimal  @default(0.0000) @db.Decimal(10, 4)
  revenue_usd Decimal  @default(0.0000) @db.Decimal(10, 4)
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]

  @@index([userId])
  @@index([cost_usd])
  @@index([revenue_usd])
  @@map("batches")
}

model Job {
  id            String   @id @default(uuid())
  batchId       String
  userId        String
  status        String   @default("rendering")
  type          String   @default("video")
  templateId    String?
  /// Publicly accessible URL for the rendered output (image or video).
  result_url    String?
  /// Lambda/render error details if status = "failed".
  error_message String?
  /// JSON metadata: concept, layout_config, renderId, bucketName, renderType, etc.
  metadata      Json?
  cost_usd      Decimal  @default(0.0000) @db.Decimal(10, 4)
  revenue_usd   Decimal  @default(0.0000) @db.Decimal(10, 4)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  /// Spy Mode: reference to the creative blueprint this job was generated from
  blueprintId   String?
  /// "legacy" for old flow, "spy" for Spy Mode generated jobs
  source        String   @default("legacy")

  batch     Batch              @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  blueprint CreativeBlueprint? @relation(fields: [blueprintId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([userId])
  @@index([status])
  @@map("jobs")
}

model AdminAuditLog {
  id        String   @id @default(uuid())
  userId    String
  adminId   String   @default("system_admin")
  action    String
  amount    Int?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([adminId])
  @@map("admin_audit_logs")
}

model BugReport {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  message   String
  batchId   String?
  status    String   @default("open") // open, resolved
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bug_reports")
}

// ─── Spy Mode Models ──────────────────────────────────────────────────────────

model StoreAnalysis {
  id              String   @id @default(uuid())
  userId          String
  storeUrl        String
  storeName       String?
  productCategory String?
  niche           String?
  priceRange      String?
  usps            Json?
  toneOfVoice     String?
  targetMarket    String?
  rawAnalysis     Json?
  status          String   @default("pending") // pending | analyzing | done | failed | manual_fallback
  errorMessage    String?
  productImageUrl String?  // Global product image for all creatives in this project
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  competitors CompetitorAnalysis[]

  @@index([userId])
  @@map("store_analyses")
}

model CompetitorAnalysis {
  id                 String   @id @default(uuid())
  storeAnalysisId    String
  competitorName     String
  competitorUrl      String?
  positioning        String?
  priceRange         String?
  marketingChannels  Json?
  relevanceScore     Int      @default(5)
  isSelected         Boolean  @default(true)
  isManual           Boolean  @default(false)
  metaAdLibraryUrl   String?
  tiktokAdLibraryUrl String?
  createdAt          DateTime @default(now())

  storeAnalysis StoreAnalysis       @relation(fields: [storeAnalysisId], references: [id], onDelete: Cascade)
  blueprints    CreativeBlueprint[]

  @@index([storeAnalysisId])
  @@map("competitor_analyses")
}

model CreativeBlueprint {
  id                   String   @id @default(uuid())
  competitorAnalysisId String?
  storeAnalysisId      String
  creativeName         String
  creativeType         String   // ugc_video | flat_lay | comparison | asmr | lifestyle | carousel | testimonial
  description          String   @db.Text
  estimatedPerformance Json?
  reproductionPrompt   String   @db.Text
  ugcScript            String?  @db.Text
  isSelected           Boolean  @default(false)
  aspectRatio          String   @default("9:16")
  sourceLabel          String   @default("market_trend") // cloned_from_competitor | market_trend
  status               String   @default("ready") // ready | generating | done | failed
  sourceUrl             String?  // Direct URL to the original ad/post
  sourceImageUrl        String?  // Direct URL to creative image (best-effort preview)
  sourcePlatform        String?  // meta_ads | tiktok_ads | google_ads | instagram_organic | tiktok_organic | facebook_organic | youtube
  customProductImageUrl String?  // Per-creative product image override
  createdAt             DateTime @default(now())

  competitorAnalysis CompetitorAnalysis? @relation(fields: [competitorAnalysisId], references: [id], onDelete: SetNull)
  jobs               Job[]

  @@index([storeAnalysisId])
  @@index([competitorAnalysisId])
  @@map("creative_blueprints")
}

// ─── Ad Cache (ScrapeCreators) ────────────────────────────────────────────────

model CachedAd {
  id             String    @id @default(uuid())
  competitorName String
  adArchiveId    String    @unique // Meta's ad_archive_id — dedup key
  snapshotUrl    String?   @db.Text // Meta-hosted screenshot of the ad
  adText         String?   @db.Text // Ad body text
  adTitle        String?            // Ad headline
  ctaText        String?            // CTA button text (Shop Now, Learn More…)
  linkUrl        String?            // Landing page URL
  sourceUrl      String?   @db.Text // Direct link to ad in Meta Ad Library (ad.url)
  platform       String?            // facebook, instagram, messenger, etc.
  startDate      DateTime?
  isActive       Boolean   @default(true)
  rawData        Json?              // Full API response for future use
  fetchedAt      DateTime  @default(now())

  @@index([competitorName])
  @@index([fetchedAt])
  @@map("cached_ads")
}
